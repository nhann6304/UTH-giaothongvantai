graph TB
    %% Tác nhân
    KH[Khách hàng]
    NV[Nhân viên]
    QL[Quản lý chi nhánh]

    %% Tiến trình
    P1((1.0 Quản lý <br/> Sản phẩm))
    P2((2.0 Quản lý <br/> Bán hàng))
    P3((3.0 Quản lý <br/> Kho))
    P4((4.0 Quản lý <br/> Nhân sự))

    %% Kho dữ liệu
    D1[(D1: Sản phẩm)]
    D2[(D2: Hóa đơn)]
    D3[(D3: Tồn kho)]
    D4[(D4: Nhân viên)]

    %% Luồng dữ liệu cho P1
    QL -->|Thông tin SP, Danh mục| P1
    P1 -->|Lưu thông tin| D1

    %% Luồng dữ liệu cho P2
    KH -->|Yêu cầu mua| P2
    NV -->|Lập hóa đơn| P2
    P2 -->|Tra cứu đơn giá| D1
    P2 -->|Lưu hóa đơn| D2
    P2 -->|Gửi hóa đơn| KH
    P2 -->|Gửi lệnh trừ kho| P3

    %% Luồng dữ liệu cho P3
    QL -->|Thông tin nhập kho| P3
    P3 -->|Cập nhật số lượng| D3

    %% Luồng dữ liệu cho P4
    QL -->|Thông tin nhân sự| P4
    P4 -->|Lưu hồ sơ| D4

    %% Định dạng
    style D1 fill:#e1f5fe,stroke:#01579b
    style D2 fill:#e1f5fe,stroke:#01579b
    style D3 fill:#e1f5fe,stroke:#01579b
    style D4 fill:#e1f5fe,stroke:#01579b