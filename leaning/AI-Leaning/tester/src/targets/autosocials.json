        { "field": "position", "type": "MULTI", "source": "enum", "enum": "EPositionUser" },
        { "field": "status", "type": "MULTI", "source": "enum", "enum": "EStatusUser" },
        { "field": "gender", "type": "MULTI", "source": "enum", "enum": "EGender" },
