        { "field": "createdBy", "type": "MULTI", "source": "api", "optionKey": "createdBy" },
        { "field": "updatedBy", "type": "MULTI", "source": "api", "optionKey": "updatedBy" },
        { "field": "createdAt", "type": "DATE_RANGE" },
        { "field": "updatedAt", "type": "DATE_RANGE" }
      ],
      "verifyRules": {
        "rowFieldMapping": {
          "position": "position",
          "status": "status",
          "gender": "gender",
          "hasPermission": "hasPermission",
          "larks": "larks[].id",
