GEMINI_API_KEY=paste_your_api_key_here
PORT=4100
# Optional: nếu set, tester sẽ chạy headless. Bỏ trống = mở browser thật để xem AI thao tác.
PLAYWRIGHT_HEADLESS=
# Optional: model name. Mặc định gemini-2.5-flash-lite (free quota cao, đủ cho QA tool-calling).
# Nâng cấp: gemini-2.5-flash (chậm, đắt hơn nhưng reason tốt hơn cho case phức tạp).
GEMINI_MODEL=
